rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all authenticated users to read and write their own wallets
    match /wallets/{walletId} {
      // Allow read if user is authenticated and document belongs to them
      allow read: if request.auth != null && 
                     (resource == null || request.auth.uid == resource.data.uid);
      
      // Allow write/update if user is authenticated and document belongs to them
      allow write, update: if request.auth != null && 
                              request.auth.uid == resource.data.uid;
      
      // Allow create if user is authenticated and they're creating their own document
      allow create: if request.auth != null && 
                       request.auth.uid == request.resource.data.uid;
      
      // Allow delete if user is authenticated and document belongs to them
      allow delete: if request.auth != null && 
                       request.auth.uid == resource.data.uid;
    }
    
    // Transaction history per wallet
    match /transactions/{transactionId} {
      // Allow read if user is authenticated and transaction belongs to their wallet
      allow read: if request.auth != null && 
                     (resource == null || request.auth.uid == resource.data.uid);
      
      // Allow create if user is authenticated and they own the wallet
      allow create: if request.auth != null && 
                       request.auth.uid == request.resource.data.uid;
      
      // Allow update/delete if user owns the transaction
      allow update, delete: if request.auth != null && 
                               request.auth.uid == resource.data.uid;
    }
  }
}
